{
  "id": "resume",
  "name": "Resume / CV",
  "description": "Clean, printable resume with experience timeline, skills, and contact info.",
  "category": "personal",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n  <title>Resume - Your Name</title>\n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    body { font-family: 'Segoe UI', system-ui, sans-serif; background: #f1f5f9; color: #1e293b; }\n    .page { max-width: 800px; margin: 32px auto; background: white; border-radius: 16px; box-shadow: 0 4px 24px rgba(0,0,0,0.08); overflow: hidden; }\n    .header { background: linear-gradient(135deg, #1e293b, #334155); color: white; padding: 48px; }\n    .header h1 { font-size: 2.5rem; margin-bottom: 8px; }\n    .header p { opacity: 0.85; font-size: 1.1rem; }\n    .contact { display: flex; gap: 24px; margin-top: 16px; flex-wrap: wrap; font-size: 0.9rem; opacity: 0.8; }\n    main { padding: 48px; }\n    h2 { font-size: 1.4rem; color: #3b82f6; border-bottom: 2px solid #e2e8f0; padding-bottom: 8px; margin: 32px 0 20px; }\n    h2:first-child { margin-top: 0; }\n    .job { margin-bottom: 24px; }\n    .job h3 { font-size: 1.1rem; }\n    .job .meta { color: #64748b; font-size: 0.9rem; margin: 4px 0 8px; }\n    .job ul { padding-left: 20px; color: #475569; line-height: 1.7; }\n    .skills { display: flex; flex-wrap: wrap; gap: 10px; }\n    .skills span { background: #eef2ff; color: #4f46e5; padding: 6px 16px; border-radius: 99px; font-size: 0.85rem; }\n    @media print { body { background: white; } .page { box-shadow: none; margin: 0; border-radius: 0; } }\n  </style>\n</head>\n<body>\n  <div class=\"page\">\n    <div class=\"header\">\n      <h1>Your Name</h1>\n      <p>Software Engineer</p>\n      <div class=\"contact\">\n        <span>your.email@example.com</span>\n        <span>San Francisco, CA</span>\n      </div>\n    </div>\n    <main>\n      <h2>Experience</h2>\n      <div class=\"job\">\n        <h3>Senior Developer</h3>\n        <p class=\"meta\">Tech Corp &bull; 2022 - Present</p>\n        <ul>\n          <li>Led a team of 5 engineers building a real-time analytics platform</li>\n          <li>Reduced page load times by 40% through performance optimization</li>\n        </ul>\n      </div>\n      <div class=\"job\">\n        <h3>Full Stack Developer</h3>\n        <p class=\"meta\">StartupCo &bull; 2019 - 2022</p>\n        <ul>\n          <li>Built the core product from prototype to 50k monthly active users</li>\n          <li>Designed and implemented RESTful APIs serving 2M requests/day</li>\n        </ul>\n      </div>\n      <h2>Skills</h2>\n      <div class=\"skills\">\n        <span>Python</span><span>JavaScript</span><span>React</span><span>PostgreSQL</span><span>Docker</span><span>AWS</span>\n      </div>\n    </main>\n  </div>\n</body>\n</html>"
}
