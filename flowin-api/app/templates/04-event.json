{
  "id": "event",
  "name": "Event Page",
  "description": "Beautiful event invitation with details, schedule, and RSVP section.",
  "category": "event",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n  <title>You're Invited!</title>\n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    body { font-family: 'Georgia', serif; background: #fef7f0; color: #44403c; }\n    .hero { background: linear-gradient(135deg, #f97316, #ec4899); color: white; padding: 100px 24px; text-align: center; }\n    .hero h1 { font-size: clamp(2.5rem, 7vw, 4rem); margin-bottom: 12px; font-style: italic; }\n    .hero p { font-size: 1.3rem; opacity: 0.9; }\n    main { max-width: 700px; margin: 0 auto; padding: 48px 24px; }\n    .details { background: white; border-radius: 20px; padding: 40px; box-shadow: 0 8px 30px rgba(0,0,0,0.06); margin-bottom: 32px; }\n    .details h2 { font-size: 1.5rem; color: #f97316; margin-bottom: 24px; }\n    .detail-row { display: flex; gap: 16px; margin-bottom: 16px; align-items: baseline; }\n    .detail-row strong { min-width: 80px; color: #78716c; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em; }\n    .detail-row span { font-size: 1.1rem; }\n    .schedule { list-style: none; }\n    .schedule li { padding: 12px 0; border-bottom: 1px solid #f5f0eb; display: flex; gap: 16px; }\n    .schedule li:last-child { border: none; }\n    .schedule time { font-weight: bold; color: #f97316; min-width: 80px; }\n    footer { text-align: center; padding: 32px; color: #a8a29e; font-size: 0.9rem; }\n  </style>\n</head>\n<body>\n  <div class=\"hero\">\n    <h1>Summer Garden Party</h1>\n    <p>Saturday, July 12th 2025</p>\n  </div>\n  <main>\n    <div class=\"details\">\n      <h2>Event Details</h2>\n      <div class=\"detail-row\"><strong>When</strong><span>July 12, 2025 at 4:00 PM</span></div>\n      <div class=\"detail-row\"><strong>Where</strong><span>123 Garden Lane, Meadowville</span></div>\n      <div class=\"detail-row\"><strong>Dress</strong><span>Smart casual, bring sunglasses!</span></div>\n    </div>\n    <div class=\"details\">\n      <h2>Schedule</h2>\n      <ul class=\"schedule\">\n        <li><time>4:00 PM</time><span>Doors open, welcome drinks</span></li>\n        <li><time>5:00 PM</time><span>Garden games and music</span></li>\n        <li><time>6:30 PM</time><span>Dinner and toasts</span></li>\n        <li><time>8:00 PM</time><span>Dancing under the stars</span></li>\n      </ul>\n    </div>\n  </main>\n  <footer>Built with Flowin</footer>\n</body>\n</html>"
}
